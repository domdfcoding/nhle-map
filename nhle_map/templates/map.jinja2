<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        {#- TODO: <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,{% filter base64_encode %}{% include "sidebar_icons/map.svg" %}{% endfilter %}"> #}
        <title>England Listed Buildings Map</title>

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
              rel="stylesheet"
              integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
              crossorigin="anonymous">
        <link rel="stylesheet" href="style.css" />
        {{ header|safe }}

        {% block extrahead %}
        {% endblock extrahead %}
    </head>

    <body>
        {% block loading_bar %}
            <!-- Loading Bar Modal -->
            <div class="modal fade"
                 id="progress"
                 data-bs-backdrop="static"
                 data-bs-keyboard="false"
                 tabindex="-1"
                 aria-labelledby="progressLabel"
                 aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h1 class="modal-title fs-5" id="progressLabel">Loading markers for area...</h1>
                        </div>
                        <div class="modal-body">
                            <div class="progress"
                                 role="progressbar"
                                 aria-label="Example with label"
                                 aria-valuenow="0"
                                 aria-valuemin="0"
                                 aria-valuemax="100">
                                <div class="progress-bar  progress-bar-striped progress-bar-animated"
                                     id="progress-bar"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% endblock loading_bar %}

        {% block main %}
            <main class="map-container p-2">
                {% block body %}
                    {{ body|safe }}
                    <p>
                        Zoom level: <span id="zoom"></span>
                    </p>
                {% endblock body %}

            </main>
        {% endblock main %}

        {% block scripts %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
                    integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
                    crossorigin="anonymous"></script>

            {{ scripts|safe }}
            <script>{{ script|safe }}

            map.on('zoomend', showZoomLevel);
            showZoomLevel();

            function showZoomLevel() {
                document.getElementById('zoom').innerHTML = map.getZoom();
            }

            {# TODO: hyperlink and add "crown copyright" #}
            map.attributionControl.setPrefix(`<a target="_blank" href="https://leafletjs.com" title="A JavaScript library for interactive maps">🇺🇦 Leaflet</a> | Data © Historic England 2026 (OGL)`)
            </script>
        {% endblock scripts %}
    </body>
</html>
